# 宝宸专利管理系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 数据库配置
DB_USER=baochen
DB_PASSWORD=baochen123
DB_NAME=baochen_mgmt
DB_PORT=5432

# JWT 配置
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 配置（多个源用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost

# 端口配置
FRONTEND_PORT=3000
BACKEND_PORT=8000
